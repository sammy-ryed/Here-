# Configuration file for Flask backend
# Copy this to .env and update values as needed

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
HOST=0.0.0.0
PORT=5000

# Database Configuration
DATABASE_PATH=db/attendance.db

# Face Recognition Settings
CONFIDENCE_THRESHOLD=0.6
MODEL_NAME=ArcFace
DETECTOR_BACKEND=retinaface

# Upload Settings
UPLOAD_FOLDER=uploads
UNRECOGNIZED_FOLDER=unrecognized
MAX_CONTENT_LENGTH=16777216  # 16MB max file size

# Allowed file extensions
ALLOWED_EXTENSIONS=png,jpg,jpeg

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Face Detection Settings
MIN_FACE_SIZE=100
MAX_FACES_PER_IMAGE=50

# Face Recognition Settings
EMBEDDING_DIMENSION=512
MIN_SAMPLES_PER_STUDENT=3
MAX_SAMPLES_PER_STUDENT=10

# Performance Settings
PRELOAD_EMBEDDINGS=True
USE_GPU=False  # Set to True if GPU is available
