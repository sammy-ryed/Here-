<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.attendance.controller.DashboardController"
      spacing="20" styleClass="content-pane">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <!-- Statistics Cards -->
    <HBox spacing="20" alignment="CENTER">
        <VBox styleClass="stat-card" alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Total Students" styleClass="stat-label"/>
            <Label fx:id="totalStudentsLabel" text="0" styleClass="stat-value"/>
        </VBox>
        
        <VBox styleClass="stat-card" alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Present Today" styleClass="stat-label"/>
            <Label fx:id="presentTodayLabel" text="0" styleClass="stat-value"/>
        </VBox>
        
        <VBox styleClass="stat-card" alignment="CENTER" spacing="10" HBox.hgrow="ALWAYS">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Attendance %" styleClass="stat-label"/>
            <Label fx:id="attendancePercentLabel" text="0%" styleClass="stat-value"/>
        </VBox>
    </HBox>
    
    <!-- Student List -->
    <VBox VBox.vgrow="ALWAYS" spacing="10">
        <Label text="Registered Students" styleClass="section-title"/>
        
        <HBox spacing="10" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Search students..." HBox.hgrow="ALWAYS"/>
            <Button text="Clear Today's Attendance" onAction="#handleClearTodayAttendance" styleClass="danger-button"/>
            <Button text="Refresh" onAction="#handleRefresh" styleClass="secondary-button"/>
        </HBox>
        
        <TableView fx:id="studentsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60"/>
                <TableColumn fx:id="rollNoColumn" text="Roll No" prefWidth="100"/>
                <TableColumn fx:id="nameColumn" text="Name" prefWidth="180"/>
                <TableColumn fx:id="presentTodayColumn" text="Present Today" prefWidth="120"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="lastAttendanceColumn" text="Last Attendance" prefWidth="150"/>
                <TableColumn fx:id="actionsColumn" text="Mark Attendance" prefWidth="160"/>
            </columns>
        </TableView>
    </VBox>
    
</VBox>
