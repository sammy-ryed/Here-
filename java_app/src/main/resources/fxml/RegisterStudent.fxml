<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.attendance.controller.RegisterStudentController"
      spacing="20" styleClass="content-pane">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Register New Student" styleClass="page-title"/>
    
    <GridPane hgap="15" vgap="15" maxWidth="600">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="120"/>
            <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>
        
        <!-- Student Name -->
        <Label text="Student Name:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="nameField" promptText="Enter full name" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        
        <!-- Roll Number -->
        <Label text="Roll Number:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="rollNoField" promptText="Enter roll number" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
    </GridPane>
    
    <Separator/>
    
    <Label text="Add Face Photos (3-5 photos recommended)" styleClass="section-title"/>
    
    <!-- Photo Upload Section -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <Button text="Upload Photos" onAction="#handleUploadPhotos" styleClass="secondary-button"/>
        <Button text="Capture Photo" onAction="#handleCapturePhoto" styleClass="secondary-button"/>
        <Label fx:id="photoCountLabel" text="0 photos added"/>
    </HBox>
    
    <!-- Photo Preview -->
    <ScrollPane fx:id="photoScrollPane" fitToWidth="true" prefHeight="200">
        <FlowPane fx:id="photoPreviewPane" hgap="10" vgap="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </FlowPane>
    </ScrollPane>
    
    <!-- Progress Bar -->
    <ProgressBar fx:id="progressBar" progress="0" prefWidth="Infinity" visible="false"/>
    <Label fx:id="statusLabel" text="" styleClass="status-message"/>
    
    <!-- Action Buttons -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <padding>
            <Insets top="10"/>
        </padding>
        <Button text="Register Student" onAction="#handleRegister" styleClass="primary-button"/>
        <Button text="Clear Form" onAction="#handleClear" styleClass="secondary-button"/>
    </HBox>
    
</VBox>
